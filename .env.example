# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# SEC EDGAR identity — required by SEC fair access policy
# Must be a real professional/institutional email (e.g. yourname@company.com)
# Gmail, Yahoo, Hotmail etc. will be rate-limited or blocked by SEC servers
EDGAR_IDENTITY=yourname@yourcompany.com
